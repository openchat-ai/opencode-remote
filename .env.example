# OpenCode Remote 配置
# 复制此文件为 .env 并填入实际值

# Telegram Bot Token (从 @BotFather 获取)
# TELEGRAM_BOT_TOKEN=

# 飞书 App 配置 (从 https://open.feishu.cn/app 获取)
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=

# 七牛云存储配置 (用于微信上传构建产物，可选)
# QINIU_ACCESS_KEY=
# QINIU_SECRET_KEY=
# QINIU_BUCKET=
# QINIU_DOMAIN=
# QINIU_REGION=cn-east-1

# OpenCode 服务器地址
# OPENCODE_SERVER_URL=http://localhost:3000

# 代理配置 (可选)
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# 请求超时 (分钟, 默认30)
# OPENCODE_REQUEST_TIMEOUT_MINUTES=30

# SESSION_IDLE_TIMEOUT_MS=1800000
# CLEANUP_INTERVAL_MS=300000
# APPROVAL_TIMEOUT_MS=300000
